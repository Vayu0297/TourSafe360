const MiniMap: React.FC<{ tourists: Tourist[]; geofences: Geofence[]; height?: number }> = ({ tourists, geofences, height = 420 }) => {
  const mapToSVG = (lat: number, lng: number, w = 700, h = 420) => ({
    x: ((lng - 88) / 9) * w,
    y: h - ((lat - 22) / 6) * h,
  });

  return (
    <svg viewBox="0 0 700 420" style={{ width:"100%", height, borderRadius:12, background:"rgba(5,10,25,0.8)" }}>
      <defs>
        <radialGradient id="glow-green"><stop offset="0%" stopColor={palette.success} stopOpacity="0.6"/><stop offset="100%" stopColor={palette.success} stopOpacity="0"/></radialGradient>
        <radialGradient id="glow-red"><stop offset="0%" stopColor={palette.danger} stopOpacity="0.6"/><stop offset="100%" stopColor={palette.danger} stopOpacity="0"/></radialGradient>
        <radialGradient id="glow-yellow"><stop offset="0%" stopColor={palette.warning} stopOpacity="0.5"/><stop offset="100%" stopColor={palette.warning} stopOpacity="0"/></radialGradient>
        <filter id="blur-sm"><feGaussianBlur stdDeviation="2"/></filter>
      </defs>
      {[0,1,2,3,4,5,6].map(i => <line key={`h${i}`} x1="0" y1={i*70} x2="700" y2={i*70} stroke={palette.border} strokeWidth="0.5"/>)}
      {[0,1,2,3,4,5,6,7].map(i => <line key={`v${i}`} x1={i*100} y1="0" x2={i*100} y2="420" stroke={palette.border} strokeWidth="0.5"/>)}
      {[
        { name:"ASSAM", lat:26.2, lng:92.5 }, { name:"MEGHALAYA", lat:25.5, lng:91.3 },
        { name:"NAGALAND", lat:26.1, lng:94.5 }, { name:"MANIPUR", lat:24.8, lng:93.9 },
        { name:"MIZORAM", lat:23.3, lng:92.7 }, { name:"TRIPURA", lat:23.7, lng:91.3 },
        { name:"ARUNACHAL", lat:27.5, lng:93.5 }, { name:"SIKKIM", lat:27.3, lng:88.6 },
      ].map(s => {
        const p = mapToSVG(s.lat, s.lng);
        return <text key={s.name} x={p.x} y={p.y} fill={palette.textDim} fontSize="9" fontWeight="600" textAnchor="middle" opacity="0.5" fontFamily="monospace">{s.name}</text>;
      })}
      {geofences.map(g => {
        const p = mapToSVG(g.center_lat, g.center_lng);
        const col = g.zone_type === "danger" ? palette.danger : g.zone_type === "restricted" ? palette.warning : palette.purple;
        return (
          <g key={g.id}>
            <circle cx={p.x} cy={p.y} r={g.radius_km * 5} fill={col} opacity="0.08" stroke={col} strokeWidth="1" strokeDasharray="4 4" strokeOpacity="0.4">
              <animate attributeName="r" values={`${g.radius_km*4.5};${g.radius_km*5.5};${g.radius_km*4.5}`} dur="3s" repeatCount="indefinite"/>
            </circle>
          </g>
        );
      })}
      {tourists.filter(t => t.current_lat && t.current_lng).map(t => {
        const p = mapToSVG(t.current_lat!, t.current_lng!);
        const status = t.status || "safe";
        const col = status === "safe" ? palette.success : status === "risky" ? palette.warning : palette.danger;
        const glowId = status === "safe" ? "glow-green" : status === "risky" ? "glow-yellow" : "glow-red";
        return (
          <g key={t.id}>
            <circle cx={p.x} cy={p.y} r="16" fill={`url(#${glowId})`} filter="url(#blur-sm)">
              {status === "danger" && <animate attributeName="r" values="14;20;14" dur="1.2s" repeatCount="indefinite"/>}
            </circle>
            <circle cx={p.x} cy={p.y} r="4" fill={col} stroke="#fff" strokeWidth="1.5">
              {status !== "safe" && <animate attributeName="r" values="3.5;5;3.5" dur="1.5s" repeatCount="indefinite"/>}
            </circle>
            <text x={p.x + 8} y={p.y + 3} fill={palette.text} fontSize="8" fontFamily="monospace">{t.name?.split(" ")[0]}</text>
          </g>
        );
      })}
