                </div>
              </div>
            </GlassCard>
          );
        })}
      </div>
    </div>
  );

  const renderTourists = () => (
    <div style={{ display:"flex", flexDirection:"column", gap:20 }}>
      <div style={{ display:"flex", gap:12, alignItems:"center", flexWrap:"wrap" }}>
        <div style={{
          flex:1, minWidth:200, display:"flex", alignItems:"center", gap:8,
          background:palette.bgGlass, borderRadius:10, padding:"10px 16px",
          border:`1px solid ${palette.border}`,
        }}>
          <span style={{ color:palette.textDim }}>🔍</span>
          <input value={searchQuery} onChange={e => setSearchQuery(e.target.value)} placeholder="Search tourist by name or ID..."
