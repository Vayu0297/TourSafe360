const api = {
  async login(email: string, password: string) {
    const res = await fetch(`${API}/api/auth/login`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password }),
    });
    if (!res.ok) throw new Error("Invalid credentials");
    return res.json();
  },
  async getTourists(token: string): Promise<Tourist[]> {
    try {
      const res = await fetch(`${API}/api/tourists/active`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) return [];
      const data = await res.json();
      return Array.isArray(data) ? data : (data.tourists || []);
    } catch { return []; }
  },
  async getSOSAlerts(token: string): Promise<SOSAlert[]> {
    try {
      const res = await fetch(`${API}/api/sos/all`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) return [];
      const data = await res.json();
      return Array.isArray(data) ? data : (data.alerts || []);
    } catch { return []; }
  },
  async getGeofences(token: string): Promise<Geofence[]> {
    try {
      const res = await fetch(`${API}/api/geofence/`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) {
        const res2 = await fetch(`${API}/api/zones/`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res2.ok) return [];
        const data = await res2.json();
        return Array.isArray(data) ? data : (data.zones || []);
      }
      const data = await res.json();
      return Array.isArray(data) ? data : (data.geofences || []);
    } catch { return []; }
  },
  async resolveAlert(token: string, alertId: string) {
    return fetch(`${API}/api/sos/${alertId}/resolve`, {
      method: "PUT",
      headers: { Authorization: `Bearer ${token}` },
    });
  },
  async getAgentsStatus(token: string) {
    try {
      const res = await fetch(`${API}/api/agents/status`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      return res.ok ? await res.json() : null;
    } catch { return null; }
  },
};

