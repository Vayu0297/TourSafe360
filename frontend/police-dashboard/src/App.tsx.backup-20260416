      <div style={{ display:"flex", alignItems:"center", gap:12, marginBottom:4 }}>
        <span style={{ fontSize:14, fontWeight:700, color:palette.danger }}>△ ACTIVE ALERTS</span>
        <Badge color={palette.danger} glow={palette.dangerGlow}>{activeAlerts}</Badge>
