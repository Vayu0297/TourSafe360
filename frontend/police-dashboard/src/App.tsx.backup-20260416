                  <button onClick={() => handleResolve(aId)} style={{ padding:"6px 14px", borderRadius:8, border:`1px solid ${palette.accent}40`, background:`${palette.accent}10`, color:palette.accent, fontSize:11, fontWeight:700, cursor:"pointer" }}>✓ Resolve</button>
