const TABS = [
  { id:"dashboard", label:"Command Center", icon:"⊞" },
  { id:"map", label:"Live Map", icon:"◎" },
  { id:"tourists", label:"Tourists", icon:"⊕" },
  { id:"geofences", label:"Geofences", icon:"⬡" },
  { id:"sos", label:"SOS Alerts", icon:"△" },
  { id:"analytics", label:"Analytics", icon:"⊿" },
  { id:"intelligence", label:"Intelligence", icon:"◈" },
  { id:"settings", label:"Settings", icon:"⚙" },
];

const CommandCenter: React.FC<{ token: string; onLogout: () => void }> = ({ token, onLogout }) => {
  const [tab, setTab] = useState("dashboard");
  const [time, setTime] = useState(new Date());
  const [sidebarHover, setSidebarHover] = useState<string | null>(null);
  const [touristFilter, setTouristFilter] = useState("all");
  const [selectedAlert, setSelectedAlert] = useState<SOSAlert | null>(null);
  const [searchQuery, setSearchQuery] = useState("");
  const [settingsToggles, setSettingsToggles] = useState({ geoAlert: true, sosBroadcast: true, locationPing: true, aiTriage: true, nightMode: true, voiceAlert: false });

  // Live data
  const [tourists, setTourists] = useState<Tourist[]>([]);
  const [alerts, setAlerts] = useState<SOSAlert[]>([]);
  const [geofences, setGeofences] = useState<Geofence[]>([]);
  const [agentsStatus, setAgentsStatus] = useState<any>(null);
  const [dataLoading, setDataLoading] = useState(true);

  // Socket.IO
  const socketRef = useRef<Socket | null>(null);

  // ─── INIT: Connect socket + initial fetch ─────────────────────
  useEffect(() => {
    const sock = io(API, { transports: ["websocket", "polling"] });
    socketRef.current = sock;

    sock.on("connect", () => console.log("[Socket] Connected"));
    sock.on("sos_alert", (alert: SOSAlert) => {
      setAlerts(prev => [alert, ...prev]);
      // Audio alert if enabled
      if (settingsToggles.voiceAlert) {
        try { new Audio("data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YU").play().catch(() => {}); } catch {}
      }
    });
    sock.on("location_update", (update: any) => {
      setTourists(prev => prev.map(t => t.id === update.tourist_id
        ? { ...t, current_lat: update.latitude, current_lng: update.longitude, last_seen: 0 }
        : t));
    });
    sock.on("geofence_breach", (breach: SOSAlert) => {
      setAlerts(prev => [breach, ...prev]);
    });

    return () => { sock.disconnect(); };
  }, []);

  // ─── DATA LOADER ──────────────────────────────────────────────
  const loadData = useCallback(async () => {
    const [t, a, g, ag] = await Promise.all([
      api.getTourists(token),
      api.getSOSAlerts(token),
      api.getGeofences(token),
      api.getAgentsStatus(token),
    ]);
    setTourists(t.length ? t : DEMO_TOURISTS);
    setAlerts(a.length ? a : DEMO_ALERTS);
    setGeofences(g.length ? g : DEMO_GEOFENCES);
    setAgentsStatus(ag);
    setDataLoading(false);
  }, [token]);

  useEffect(() => {
    loadData();
    const i = setInterval(loadData, 30000); // refresh every 30s
    return () => clearInterval(i);
  }, [loadData]);

  useEffect(() => {
    const i = setInterval(() => setTime(new Date()), 1000);
    return () => clearInterval(i);
  }, []);

  // ─── DERIVED ──────────────────────────────────────────────────
  const safeTourists = tourists.filter(t => t.status === "safe").length;
  const riskyTourists = tourists.filter(t => t.status === "risky").length;
  const dangerTourists = tourists.filter(t => t.status === "danger").length;
  const activeAlerts = alerts.filter(a => a.status !== "resolved").length;

  const filteredTourists = tourists.filter(t => {
    if (touristFilter !== "all" && t.status !== touristFilter) return false;
    if (searchQuery && !t.name?.toLowerCase().includes(searchQuery.toLowerCase()) && !t.id?.toLowerCase().includes(searchQuery.toLowerCase())) return false;
    return true;
  });

  const handleResolve = async (alertId: string) => {
    await api.resolveAlert(token, alertId);
    setAlerts(prev => prev.map(a => (a.id === alertId || a.alert_id === alertId) ? { ...a, status: "resolved" } : a));
    setSelectedAlert(null);
  };

  // ─── INTELLIGENCE (computed from real data) ───────────────────
  const intelligenceInsights = computeIntelligence(tourists, alerts, geofences);

  // ═══════════════════════════════════════════════════════════════
  // RENDER TABS
