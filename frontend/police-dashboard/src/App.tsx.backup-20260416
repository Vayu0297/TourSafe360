// INTELLIGENCE COMPUTATION (uses real data)
// ═══════════════════════════════════════════════════════════════
function computeIntelligence(tourists: Tourist[], alerts: SOSAlert[], geofences: Geofence[]) {
  const recentAlerts = alerts.filter(a => a.status !== "resolved");

  // Risk per geofence based on nearby alerts
  const riskPredictions = geofences.slice(0, 6).map(g => {
    const nearbyAlerts = alerts.filter(a => {
      const dLat = Math.abs(a.latitude - g.center_lat);
      const dLng = Math.abs(a.longitude - g.center_lng);
      return Math.sqrt(dLat*dLat + dLng*dLng) < g.radius_km / 100;
    });
    const baseRisk = g.zone_type === "danger" ? 70 : g.zone_type === "restricted" ? 50 : 35;
    const risk = Math.min(95, baseRisk + nearbyAlerts.length * 8);
    return {
      zone: g.name,
      risk,
      trend: nearbyAlerts.length > 2 ? "up" : nearbyAlerts.length === 0 ? "down" : "stable",
      incidents: nearbyAlerts.length,
      factor: g.description || `${g.zone_type} zone`,
    };
  });

  // AI insights from real data
  const aiInsights = [];
  const dangerCount = tourists.filter(t => t.status === "danger").length;
  if (dangerCount > 0) aiInsights.push({ text: `${dangerCount} tourist(s) in critical danger status — immediate attention required`, priority: "critical", time: "now" });

  const riskyByState: Record<string, number> = {};
  tourists.filter(t => t.status === "risky").forEach(t => { if (t.state) riskyByState[t.state] = (riskyByState[t.state] || 0) + 1; });
  const topRisky = Object.entries(riskyByState).sort((a,b) => b[1]-a[1])[0];
  if (topRisky) aiInsights.push({ text: `${topRisky[1]} tourists in ${topRisky[0]} showing elevated risk patterns`, priority: "high", time: "2 min ago" });

  const breachAlerts = alerts.filter(a => a.alert_type === "geofence" || a.alert_type === "geofence_breach").length;
  if (breachAlerts > 0) aiInsights.push({ text: `${breachAlerts} geofence breach event(s) detected — verify with on-ground units`, priority: "high", time: "5 min ago" });

  aiInsights.push({ text: "Weather alert: Heavy rainfall predicted in Meghalaya — landslide risk elevated", priority: "medium", time: "12 min ago" });
  aiInsights.push({ text: `${tourists.length} active tourists across 8 NE states — system tracking nominal`, priority: "low", time: "18 min ago" });

  // Weekly trend (synthetic for now — would come from /api/analytics/weekly)
  const weeklyTrend = [
    { day:"Mon", alerts:8 }, { day:"Tue", alerts:12 }, { day:"Wed", alerts:6 },
    { day:"Thu", alerts:15 }, { day:"Fri", alerts:9 }, { day:"Sat", alerts:18 }, { day:"Sun", alerts:11 },
  ];

  return { riskPredictions, aiInsights, weeklyTrend };
}

