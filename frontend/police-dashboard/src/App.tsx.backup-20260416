              <span style={{ color:palette.danger }}>△</span> LIVE ALERTS
            </span>
            <Badge color={palette.danger} glow={palette.dangerGlow}>{activeAlerts}</Badge>
          </div>
          <div style={{ display:"flex", flexDirection:"column", gap:10, maxHeight:380, overflowY:"auto" }}>
            {alerts.filter(a => a.status !== "resolved").slice(0, 6).map((a, i) => {
              const typeCol = a.alert_type === "sos" || a.alert_type === "medical" ? palette.danger
                : a.alert_type === "geofence" || a.alert_type === "geofence_breach" ? palette.warning
                : palette.purple;
              const typeLabel = (a.alert_type || "ALERT").toUpperCase().slice(0, 12);
              return (
                <div key={a.id || a.alert_id || i} onClick={() => setSelectedAlert(a)} style={{
                  background:"rgba(255,255,255,0.03)", borderRadius:10, padding:12,
                  borderLeft:`3px solid ${typeCol}`, cursor:"pointer",
                  opacity: 0, animation:`fadeSlideIn 0.4s ${i * 0.1}s forwards`,
                }}>
                  <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:6 }}>
                    <span style={{ fontWeight:700, fontSize:13, color:palette.text }}>{a.tourist_name || "Unknown"}</span>
                    <Badge color={typeCol}>{typeLabel}</Badge>
                  </div>
                  <div style={{ fontSize:11, color:palette.textDim, lineHeight:1.6 }}>
                    {a.message || "Alert triggered"}<br/>
                    <span style={{ opacity:0.7 }}>📍 {a.latitude?.toFixed(3)}, {a.longitude?.toFixed(3)} · ⏰ {a.created_at?.slice(11, 19) || "Now"}</span>
                  </div>
                </div>
              );
            })}
            {alerts.length === 0 && <div style={{ color:palette.textDim, fontSize:12, padding:20, textAlign:"center" }}>No active alerts ✓</div>}
          </div>
        </GlassCard>
      </div>

      <GlassCard delay={400}>
        <div style={{ fontSize:13, fontWeight:700, color:palette.text, marginBottom:14 }}>
          <span style={{ color:palette.purple }}>◈</span> AI INTELLIGENCE FEED
        </div>
        <div style={{ display:"flex", gap:12, overflowX:"auto", paddingBottom:8 }}>
          {intelligenceInsights.aiInsights.slice(0, 4).map((insight, i) => {
            const col = insight.priority === "critical" ? palette.danger : insight.priority === "high" ? palette.warning : insight.priority === "medium" ? palette.accent : palette.success;
            return (
              <div key={i} style={{
                minWidth:240, padding:14, borderRadius:10,
                background:`linear-gradient(135deg, ${col}08, ${col}03)`, border:`1px solid ${col}20`,
                opacity: 0, animation:`fadeSlideIn 0.5s ${0.5 + i * 0.1}s forwards`,
              }}>
                <div style={{ display:"flex", justifyContent:"space-between", marginBottom:8 }}>
                  <Badge color={col}>{insight.priority}</Badge>
                  <span style={{ fontSize:10, color:palette.textDim }}>{insight.time}</span>
                </div>
                <div style={{ fontSize:12, color:palette.text, lineHeight:1.5 }}>{insight.text}</div>
              </div>
            );
          })}
        </div>
      </GlassCard>
    </div>
  );

  const renderMap = () => (
    <div style={{ display:"flex", flexDirection:"column", gap:20 }}>
      <GlassCard delay={100}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
          <div style={{ fontSize:14, fontWeight:700, color:palette.text }}>
            <span style={{ color:palette.accent }}>◎</span> NORTHEAST INDIA — REAL-TIME TRACKING
          </div>
          <div style={{ display:"flex", gap:16, fontSize:11, color:palette.textDim }}>
            <span style={{ display:"flex", alignItems:"center", gap:4 }}><span style={{ width:8, height:8, borderRadius:"50%", background:palette.success, display:"inline-block" }}/> Safe ({safeTourists})</span>
            <span style={{ display:"flex", alignItems:"center", gap:4 }}><span style={{ width:8, height:8, borderRadius:"50%", background:palette.warning, display:"inline-block" }}/> Risky ({riskyTourists})</span>
            <span style={{ display:"flex", alignItems:"center", gap:4 }}><span style={{ width:8, height:8, borderRadius:"50%", background:palette.danger, display:"inline-block" }}/> Danger ({dangerTourists})</span>
          </div>
        </div>
        <MiniMap tourists={tourists} geofences={geofences} height={520}/>
      </GlassCard>
      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(280px, 1fr))", gap:16 }}>
