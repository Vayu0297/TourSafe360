            <div style={{ fontSize:11, color:palette.textDim, marginBottom:8, letterSpacing:1 }}>PASSWORD</div>
            <input type="password" value={password} onChange={e => setPassword(e.target.value)}
              placeholder="••••••••"
              onKeyDown={e => e.key === "Enter" && handleLogin()}
              style={{
                width:"100%", padding:"12px 14px", borderRadius:10,
                background:"rgba(0,0,0,0.3)", border:`1px solid ${palette.border}`,
                color:palette.text, fontSize:13, outline:"none", transition:"all 0.2s",
                fontFamily:"inherit",
              }}
              onFocus={e => { e.target.style.borderColor = palette.accent; e.target.style.boxShadow = palette.accentGlow; }}
              onBlur={e => { e.target.style.borderColor = palette.border; e.target.style.boxShadow = "none"; }}
            />
          </div>

          {error && (
            <div style={{
              padding:"10px 14px", borderRadius:8, marginBottom:16,
              background:`${palette.danger}15`, border:`1px solid ${palette.danger}40`,
              color:palette.danger, fontSize:12,
            }}>⚠ {error}</div>
          )}

          <button onClick={handleLogin} disabled={loading} style={{
            width:"100%", padding:"14px", borderRadius:10, border:"none",
            background: loading ? palette.border : `linear-gradient(135deg, ${palette.accent}, ${palette.purple})`,
            color:"#fff", fontSize:13, fontWeight:700, letterSpacing:1, textTransform:"uppercase",
            cursor: loading ? "not-allowed" : "pointer", transition:"all 0.2s",
            animation: loading ? "none" : "glow-pulse 2s infinite",
          }}>
            {loading ? "Authenticating..." : "Access Command Center →"}
          </button>

          <div style={{ marginTop:20, paddingTop:20, borderTop:`1px solid ${palette.border}`,
            fontSize:11, color:palette.textDim, textAlign:"center", lineHeight:1.6 }}>
            <Pulse color={palette.success} size={6} style={{ marginRight:6 }}/>
            System online · v2.0.0 · Backend: <span style={{ fontFamily:"monospace", color:palette.accent }}>{API.replace("http://","")}</span>
          </div>
        </div>
      </div>
    </div>
  );
};

