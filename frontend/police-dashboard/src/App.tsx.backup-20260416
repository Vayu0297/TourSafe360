              <div style={{ fontSize:12, color:palette.textDim, lineHeight:1.6, marginTop:10 }}>
                {g.description || "Zone monitoring active"}<br/>
                <span style={{ fontFamily:"'JetBrains Mono', monospace", fontSize:11 }}>
                  📍 {g.state || "NE"} · R: {g.radius_km}km · {g.center_lat?.toFixed(3)}, {g.center_lng?.toFixed(3)}
                </span>
              </div>
            </GlassCard>
          );
        })}
      </div>
    </div>
