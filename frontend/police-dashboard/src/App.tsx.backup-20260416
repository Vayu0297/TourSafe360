            : a.alert_type === "geofence" || a.alert_type === "geofence_breach" ? palette.warning
            : palette.purple;
          const typeLabel = (a.alert_type || "ALERT").replace("_", " ").toUpperCase();
          const isSelected = selectedAlert?.id === a.id || selectedAlert?.alert_id === a.alert_id;
          return (
            <GlassCard key={aId} delay={i * 80} onClick={() => setSelectedAlert(isSelected ? null : a)}
