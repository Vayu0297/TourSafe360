        <StatCard label="At Risk" value={riskyTourists} icon="⚡" color={palette.warning} delay={200}/>
        <StatCard label="In Danger" value={dangerTourists} icon="🚨" color={palette.danger} delay={300}/>
        <StatCard label="SOS Active" value={activeAlerts} icon="△" color={palette.purple} delay={400}/>
